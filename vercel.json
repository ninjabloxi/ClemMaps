{
  "version": 2,

  "cleanUrls": true,

  "trailingSlash": false,

  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },

    {
      "source": "/settings",
      "destination": "/pages/settings.html"
    },

    {
      "source": "/vehicle",
      "destination": "/pages/vehicle.html"
    },

    {
      "source": "/navigation",
      "destination": "/pages/navigation.html"
    }
  ],

  "headers": [
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    },

    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css"
        }
      ]
    },

    {
      "source": "/(.*).json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}